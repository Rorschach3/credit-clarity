{
  "target": "dashboard",
  "variant": 2,
  "variant_name": "Top Nav + Bento Grid",
  "description": "Horizontal top navigation, full-width bento-grid layout. Credit score hero card spans 2 columns. Modern, spacious.",
  "template": {
    "dom_structure": {
      "tag": "div",
      "class": "layout-dashboard-v2",
      "children": [
        {
          "tag": "nav",
          "class": "topnav",
          "children": [
            { "tag": "div", "class": "topnav-logo" },
            { "tag": "div", "class": "topnav-links" },
            { "tag": "div", "class": "topnav-user" }
          ]
        },
        {
          "tag": "main",
          "class": "bento-canvas",
          "children": [
            { "tag": "div", "class": "bento-hero" },
            { "tag": "div", "class": "bento-score" },
            { "tag": "div", "class": "bento-disputes" },
            { "tag": "div", "class": "bento-tradelines" },
            { "tag": "div", "class": "bento-activity" },
            { "tag": "div", "class": "bento-actions" }
          ]
        }
      ]
    },
    "css_layout_rules": {
      ".layout-dashboard-v2": "display: flex; flex-direction: column; min-height: 100vh;",
      ".topnav": "height: 64px; display: flex; align-items: center; padding: 0 2rem; gap: 2rem; position: sticky; top: 0; z-index: 40; border-bottom: 1px solid var(--border);",
      ".topnav-links": "display: flex; gap: 0.5rem; flex: 1;",
      ".bento-canvas": "display: grid; grid-template-columns: repeat(12, 1fr); grid-auto-rows: minmax(120px, auto); gap: 1.25rem; padding: 2rem; flex: 1;",
      ".bento-hero": "grid-column: span 8; grid-row: span 2;",
      ".bento-score": "grid-column: span 4; grid-row: span 2;",
      ".bento-disputes": "grid-column: span 4; grid-row: span 2;",
      ".bento-tradelines": "grid-column: span 8; grid-row: span 3;",
      ".bento-activity": "grid-column: span 4; grid-row: span 3;",
      ".bento-actions": "grid-column: span 12;",
      "@media (max-width: 1024px)": {
        ".bento-canvas": "grid-template-columns: 1fr 1fr;",
        ".bento-hero, .bento-score, .bento-disputes, .bento-tradelines, .bento-activity, .bento-actions": "grid-column: span 2;"
      },
      "@media (max-width: 640px)": {
        ".bento-canvas": "grid-template-columns: 1fr;",
        ".bento-hero, .bento-score, .bento-disputes, .bento-tradelines, .bento-activity, .bento-actions": "grid-column: span 1;"
      }
    }
  }
}
